# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hakusan_monitor
# For Supabase: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# Supabase (optional - for Storage/Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Device API Keys (comma-separated)
DEVICE_API_KEYS=hakusan_key_001,hakusan_key_002

# Open-Meteo (no key required)
OPEN_METEO_LATITUDE=36.1533
OPEN_METEO_LONGITUDE=136.7717
OPEN_METEO_ELEVATION=2702

# AI Analysis
AI_MODEL_PATH=./models/detectron2_config.yaml
AI_CONFIDENCE_THRESHOLD=0.5

# CORS
CORS_ORIGINS=https://ishikawa8.github.io,http://localhost:3000,http://localhost:8000

# Environment
ENVIRONMENT=development
